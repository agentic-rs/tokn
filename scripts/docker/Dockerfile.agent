# syntax=docker/dockerfile:1.7

FROM node:22-bookworm-slim

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
  --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
  rm -f /var/cache/apt/archives/lock /var/lib/apt/lists/lock /var/lib/dpkg/lock /var/lib/dpkg/lock-frontend \
  && apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl git

RUN --mount=type=cache,target=/root/.npm \
  npm install -g @openai/codex opencode-ai @earendil-works/pi-coding-agent

COPY agent-entrypoint.sh /usr/local/bin/tokn-agent-entrypoint
RUN chmod +x /usr/local/bin/tokn-agent-entrypoint

WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/tokn-agent-entrypoint"]
