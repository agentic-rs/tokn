FROM node:22-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl git \
  && rm -rf /var/lib/apt/lists/* \
  && npm install -g @openai/codex opencode-ai @earendil-works/pi-coding-agent

COPY agent-entrypoint.sh /usr/local/bin/tokn-agent-entrypoint
RUN chmod +x /usr/local/bin/tokn-agent-entrypoint

WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/tokn-agent-entrypoint"]
